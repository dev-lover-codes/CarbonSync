rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read and write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Activities — scoped reads for any auth'd user, writes scoped to owner
    match /activities/{activityId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Goals — user can only access their own
    match /goals/{goalId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // Insights — scoped reads for any auth'd user, writes scoped to owner
    match /insights/{insightId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // Leaderboard — public read, authenticated write
    match /leaderboard/{entryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Tips — public read, no client writes
    match /tips/{tipId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
